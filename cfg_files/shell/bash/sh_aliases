


# Determining what distro is running 
release="$(cat /etc/os-release)";

case $release in
    *"Debian"* | *"debian"* | *"DEBIAN"*) 
        ### nala
        alias "inst"="sudo nala install"
        alias "upgr"="sudo nala upgrade"
        alias "remo"="sudo nala remove"
        alias "sear"="nala search"
        ;;
    *"Fedora"* | *"fedora"* | *"FEDORA"*) 
        alias "inst"="sudo dnf install"
        alias "upgr"="sudo dnf update"
        alias "remo"="sudo dnf remove"
        alias "sear"="dnf search"
        ;;
    *"Arch Linux"* | *"arch linux"* | *"ARCH LINUX"*) 
        alias "inst"="sudo pacman -S"
        alias "upgr"="sudo pacman -Syu"
        alias "remo"="sudo pacman -R"
        alias "sear"="pacman -Ss"
        ;;
esac

