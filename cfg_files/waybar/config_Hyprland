    "clock": {
    	"format": "{:%d.%m п‘•  | %R пҖ— }",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    "custom/clock":{
        "interval": "10s",
        "exec": "date \"+ %d.%m п‘•  | %R пҖ— \"",
        "format":"{}" 
    },


    "custom/kernel": {
        "interval": "once",
        "exec": "uname -r | cut -b -5",
	"format":"п…ј {}"	
    },

    "custom/drivespace": {
        "interval": "3600s",
        "exec": "df -H | grep -e '/$'| awk '{print $3}'",
        "format":"{} пӮ  ",
    },

    "custom/home": {
        "interval": "3600s",
        "exec": "df -H | grep -e '/home$'| awk '{print $3}'",
	"format":"{} пҖ• "
    },

    "custom/keyboard": {
        "interval": "once",
        "exec": "echo $(swaymsg -t get_inputs | grep \"xkb_active_layout_name\"| sed -n 1p | tr -d '\":(,.)' | awk '{print $2 \" \" $3}')" ,
        "format":"{} п„ң ",
        "signal" : 5
    },
 

    "cpu": {
        "format": "{usage}% п’ј ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% оҝ… "
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}В°C {icon}",
        "format": "{temperatureC}В°C {icon}",
        "format-icons": ["пӢҮ"]
    },
    "battery": {
