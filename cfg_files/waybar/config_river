    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    "river/tags": {
        "format": "{}"
    },

    "clock": {
    	"format": "{:%d.%m яСХ  | %R яАЧ}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },


    "custom/kernel": {
        "interval": "once",
        "exec": "uname -r | cut -b -5",
	"format":"яЕ╝ {}"	
    },

    "custom/drivespace": {
        "interval": "3600s",
        "exec": "df -H | grep -e '/$'| awk '{print $3}'",
        "format":"{} яВа ",
    },

    "custom/home": {
        "interval": "3600s",
        "exec": "df -H | grep -e '/home$'| awk '{print $3}'",
	"format":"яАХ {}"
    },

    "custom/keyboard": {
        "interval": "once",
        "exec": "echo $(swaymsg -t get_inputs | grep \"xkb_active_layout_name\"| sed -n 1p | tr -d '\":(,.)' | awk '{print $2 \" \" $3}')" ,
        "format":"{} яДЬ ",
        "signal" : 5
    },
    "custom/home": {
        "interval": "3600s",
        "exec": "df -H | grep -e '/home$'| awk '{print $3}'",
	"format":"яАХ {}"
    },
 

    "cpu": {
        "format": "{usage}% яТ╝",
        "tooltip": false
    },
    "memory": {
        "format": "{}% ю┐Е "
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["яЛЗ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% яГз",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    //"battery#bat2": {
    //    "bat": "BAT0"
    //},
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "({signalStrength}%) яЗл",
        "format-ethernet": "{ipaddr}/{cidr} юмп",
        "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪб",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яД▒ {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}
