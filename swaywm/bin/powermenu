#!/bin/bash

MENTRIES="$(echo "’Ćæ Poweroff
’Ćæ Reboot
Ņ”║ Logout
’åå Suspend
Ņö║ Hibernate
’ĆŻ Lock" | rofi -dmenu -config $HOME/.config/rofi/config2.rasi)"

MOPTIONS="$(echo $MENTRIES | awk '{print$2}' |tr '[:upper:]' '[:lower:]')"
echo $MOPTIONS

if [[ -n "$MOPTIONS" ]]
then

if [[ "$MOPTIONS" == logout ]]
then 
        swaymsg exit
else
        if [[ "$MOPTIONS" == lock ]]
        then
                swaylock
        else
                if [[ "$MOPTIONS" == shutdown ]]
                then
                        shutdown now
                else

systemctl $MOPTIONS
                fi
        fi
fi
fi
