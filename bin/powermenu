#!/bin/sh

if [ $XDG_SESSION_TYPE = 'wayland' ]; then
    menu="$(printf "пЂ‘ Poweroff \nпЂћ Reboot \nу°Ќѓ Logout \nп†† Suspend \nу°’І Hibernate \nпЂЈ Lock" | wofi --dmenu -i)"
else
    menu="$(printf "пЂ‘ Poweroff \nпЂћ Reboot \nу°Ќѓ Logout \nп†† Suspend \nу°’І Hibernate \nпЂЈ Lock" | rofi -dmenu -i -p "")"
fi


case $menu in
    *Poweroff*) systemctl poweroff;;
    *Reboot*) systemctl reboot;;
    *Logout*) loginctl terminate-user $USER;;
    *Suspend* ) lock & (sleep 1 && systemctl suspend);;
    *Lock*) lock;;
    *Hibernate* ) systemctl hibernate;;
esac

