#!/bin/sh
blockdevice="$(lsblk -l -i -o name,mountpoints | grep sd[a-z][0-9] | wofi --dmenu -p 'Which drive would you like to mount?' | awk '{print $1}')"
[ -z "$blockdevice" ] && exit 0;
(udisksctl mount -b /dev/$blockdevice && echo "Device mounted successfully" | wofi --dmenu) || (udisksctl unmount -b /dev/$blockdevice && echo "removed successfully" | wofi --dmenu) || (echo " Something went wrong: run usmount in your terminal" | wofi --dmenu)
