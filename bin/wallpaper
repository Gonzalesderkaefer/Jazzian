#!/bin/sh


if ! [ -d $HOME/Pictures/wallpapers ]; then
    mkdir $HOME/Pictures/wallpapers;
    
    if [ $XDG_SESSION_TYPE = 'wayland' ]; then
        printf "You seem to not have any Wallpapers in $HOME/Pictures/wallpapers \nPlease put some there" | wofi --dmenu;
    else
        printf "You seem to not have any Wallpapers in $HOME/Pictures/wallpapers \nPlease put some there" | rofi -dmenu -i -p "";
    fi
    exit;
fi


file=$(ls -1 $HOME/Pictures/wallpapers | wofi --dmenu);



