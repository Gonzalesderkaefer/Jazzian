#!/bin/sh

menu="$(echo "’Ćæ Poweroff
’Ć× Reboot
¾░Źā Logout
’åå Suspend
¾░Æ▓ Hibernate
’ĆŻ Lock" | rofi -dmenu -i -p "")"

case $menu in
    *Poweroff*) systemctl poweroff;;
    *Reboot*) systemctl reboot;;
    *Logout*) i3-msg exit;;
    *Suspend* ) systemctl suspend ;;
    *Lock*) i3lock -f -c 000000;;
    *Hibernate* ) systemctl hibernate;;
esac

