#!/bin/bash



# Determining what distro is running 
release="$(cat /etc/os-release)";

case $release in
    *"Debian"* | *"debian"* | *"DEBIAN"*) 
        case $XDG_SESSION_TYPE in
            "wayland")
                alacritty --config-file $HOME/.config/alacritty/alacritty.yml
                ;;
            *)
                alacritty --config-file $HOME/.config/alacritty/alacrittyx11.yml
                ;;
        esac
        ;;
    *)
        case $XDG_SESSION_TYPE in
            "wayland")
                alacritty --config-file $HOME/.config/alacritty/alacritty.toml
                ;;
            *)
                alacritty --config-file $HOME/.config/alacritty/alacrittyx11.toml
                ;;
        esac
        ;;
esac
